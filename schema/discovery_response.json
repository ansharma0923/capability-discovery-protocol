{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://adp.protocol/schema/discovery_response.json",
  "title": "DiscoveryResponse",
  "description": "The full API response from the ADP /discover endpoint",
  "type": "object",
  "version": "0.1.0",
  "required": ["intent_id", "version", "category", "total_candidates", "total_results", "results", "pipeline", "generated_at"],
  "properties": {
    "intent_id": {"type": "string"},
    "version": {"type": "string"},
    "category": {
      "type": "string",
      "enum": ["product", "service", "agent", "data", "compute", "api"]
    },
    "total_candidates": {"type": "integer", "minimum": 0},
    "total_results": {"type": "integer", "minimum": 0},
    "results": {
      "type": "array",
      "items": {"$ref": "discovery_result.json"}
    },
    "pipeline": {
      "type": "object",
      "required": ["stages_executed", "duration_ms", "federation_used"],
      "properties": {
        "stages_executed": {"type": "array", "items": {"type": "string"}},
        "duration_ms": {"type": "number", "minimum": 0},
        "federation_used": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "generated_at": {"type": "string", "format": "date-time"},
    "_federation_nodes_queried": {"type": "integer", "minimum": 0}
  },
  "additionalProperties": false
}
