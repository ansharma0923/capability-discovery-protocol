{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://adp.protocol/schema/federation_response.json",
  "title": "FederationResponse",
  "description": "A federation response from a remote CDP node",
  "type": "object",
  "version": "0.1.0",
  "required": ["federation_id", "version", "responding_node", "results", "timestamp"],
  "properties": {
    "federation_id": {"type": "string"},
    "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
    "responding_node": {"type": "string", "format": "uri"},
    "results": {
      "type": "array",
      "items": {"$ref": "discovery_result.json"}
    },
    "total_results": {"type": "integer", "minimum": 0},
    "timestamp": {"type": "string", "format": "date-time"},
    "duration_ms": {"type": "number", "minimum": 0},
    "metadata": {"type": "object"}
  },
  "additionalProperties": false
}
